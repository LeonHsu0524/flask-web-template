# ---------------------------------------------------------------------------
# Copy this file to ".env" and adjust. Every value has a safe default in
# config.py, so the app runs even without a .env. See SECRETS.md to go live.
# ---------------------------------------------------------------------------

# Which config class to load: development | production | testing
APP_ENV=development

# Core
SECRET_KEY=super-secret-key-change-this-in-production
PORT=5000
TIMEZONE=Asia/Taipei

# ===== DATABASE =====
# Change this one line to point the server at a different database.
#   SQLite (default):  sqlite:///data.db
#   PostgreSQL:        postgresql+psycopg2://user:pass@host:5432/dbname
#   MySQL:             mysql+pymysql://user:pass@host:3306/dbname
DATABASE_URL=sqlite:///data.db
USER_DATABASE_URL=sqlite:///user.db

# Backups
BACKUP_DIR=backups
RETENTION_DAYS=30

# ===== ECPay (payment) =====
# These are ECPay's official public SANDBOX credentials (merchant 2000132) and
# match the sandbox action URL below, so checkout works out of the box for
# testing. Replace all four with your own official values when going live.
# Note: the MerchantID and the action URL must be from the SAME environment.
# A production MerchantID sent to the sandbox URL (or vice versa) fails with
# "10200074 找不到加密金鑰".
ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=5294y06JbISpM5x9
ECPAY_HASH_IV=v77hoKGq4kWxNNIS
# Sandbox endpoint (default). For production, switch to the live URL:
#   Live: https://payment.ecpay.com.tw/Cashier/AioCheckOut/V5
ECPAY_ACTION_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5
# Public URL ECPay calls back to (your domain or ngrok URL).
PUBLIC_BASE_URL=http://localhost:5000
VIP_PRICE=199
VIP_DAYS=365
# Order defaults (changeable without code; create_ecpay_order can also override per call)
ECPAY_CHOOSE_PAYMENT=ALL
ECPAY_ENCRYPT_TYPE=1
ECPAY_DEFAULT_ITEM=Premium_Membership
ECPAY_TRADE_DESC=Subscription

# ===== Email (optional SMTP for password-reset links) =====
# Leave SMTP_HOST blank to just log reset links (dev). Fill in to actually email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# ===== External data API protection =====
# Comma-separated accepted X-API-Key values (one per external client).
API_KEYS=dev-test-key-change-me

# ===== Security add-ons =====
RATELIMIT_ENABLED=true
# Counter storage: memory:// (dev) or redis://host:6379 (production, multi-worker)
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=200 per minute
RATELIMIT_LOGIN=10 per minute
RATELIMIT_SAVE=60 per minute
RATELIMIT_RESET=5 per minute
WTF_CSRF_ENABLED=true
RESET_TOKEN_MAX_AGE=3600
API_TOKEN_MAX_AGE=2592000
# Set true in production (HTTPS) so the session cookie is only sent over TLS.
SESSION_COOKIE_SECURE=false
PERMANENT_SESSION_LIFETIME=86400

# ===== Registration fields (optional) =====
# Address picker (country/state dropdowns + Taiwan 縣市/鄉鎮市區 with auto zipcode,
# data vendored under static/vendor/) and a birthday calendar field. For each:
# COLLECT_* shows the field; *_REQUIRED makes it mandatory. Applies to the web
# form and POST /api/register.
REGISTER_COLLECT_ADDRESS=true
REGISTER_ADDRESS_REQUIRED=false
REGISTER_COLLECT_BIRTHDAY=true
REGISTER_BIRTHDAY_REQUIRED=false

# ===== Default admin (auto-created on first run) =====
# A working admin so a fresh deploy isn't locked out. CHANGE THE PASSWORD,
# or set DEFAULT_ADMIN_ENABLED=false once you've made your own admin.
DEFAULT_ADMIN_ENABLED=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin12345
DEFAULT_ADMIN_ROLE=superadmin
